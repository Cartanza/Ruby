{{#*inline "body"}}
<div class="gh-outer">
<main class="site-main gh-inner">

    {{#with tag}}
    <div class="term">
        <h1 class="term-name">{{name}}</h1>
        {{#if description}}
            <p class="term-description">{{description}}</p>
        {{/if}}
    </div>
    {{/with}}

    <div class="post-feed gh-feed">
        {{#foreach posts}}
            {{> partials/loop}}
        {{/foreach}}
    </div>

</main>
</div>
{{/inline}}
{{> default}}