{{#*inline "body"}}
<main class="site-main">

    {{#with post}}

    <article class="gh-article {{post_class}}">

        <header class="gh-article-header gh-canvas">
            <span class="gh-article-meta"{{#if primary_tag.accent_color}} style="--tag-color: {{primary_tag.accent_color}};"{{/if}}>
                By {{#foreach authors}}{{#if @first}}{{name}}{{else}}, {{name}}{{/if}}{{/foreach}}
                {{#if primary_tag}}
                    in
                    <a class="gh-article-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
                {{/if}}
                —
                <time datetime="{{date published_at format="YYYY-MM-DD"}}">{{date published_at format="DD MMM YYYY"}}</time>
            </span>

            <h1 class="gh-article-title">{{title}}</h1>

            {{#if custom_excerpt}}
                <p class="gh-article-excerpt">{{custom_excerpt}}</p>
            {{/if}}

            {{> partials/post-image}}
        </header>

        <div class="gh-content gh-canvas">
            {{{content}}}
        </div>

    </article>

    {{> partials/post-navigation}}

    {{#if comments}}
        <div class="gh-comments gh-canvas">
            {{comments}}
        </div>
    {{/if}}

    {{/with}}

    {{#if @root.custom.show_related_posts}}
        {{> partials/related-posts}}
    {{/if}}

</main>
{{/inline}}
{{> default}}